# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# --- ALTERNATIVE AI API ROUTERS (Optional) ---
# You can supply any of these keys or endpoints to route agents through alternative providers:
# GROQ_API_KEY="gsk_..."                  # Uses Groq (llama-3.3-70b-versatile) - fast & high rate limits
# OPENROUTER_API_KEY="sk-or-v1-..."       # Uses OpenRouter (meta-llama/llama-3.3-70b-instruct)
# DEEPSEEK_API_KEY="sk-..."              # Uses DeepSeek API (deepseek-chat)
# OPENAI_API_KEY="sk-..."                # Uses OpenAI API (gpt-4o-mini)
# OPENAI_BASE_URL="http://localhost:1234/v1" # Custom OpenAI-compatible server (LM Studio / vLLM / LocalAI)
# OPENAI_MODEL="gpt-4o-mini"             # Custom model name
# USE_OPENAI_FIRST="true"                 # Set to true to prioritize OpenAI-compatible router over Gemini
# FORCE_OLLAMA="true"                    # Set to true to route all requests through local Ollama

